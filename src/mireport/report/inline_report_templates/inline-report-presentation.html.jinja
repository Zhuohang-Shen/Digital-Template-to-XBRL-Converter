{% import "_macros.html.jinja" as macros %}
{{ aoix.namespaces }}
{{ aoix.schema_ref }}
{{ aoix.periods }}
{{ aoix.defaults }}
{% set ns = namespace(fact_count = 0) %}
{% set timestamp = now_utc() %}
<!DOCTYPE html>
<html xml:lang="{{ reportInfo.language }}"
  xmlns="http://www.w3.org/1999/xhtml"
  {{ '{{ namespaces }}' }}>
    <head>
        <!-- Generated by "{{ software.name | e }}" at {{ macros.render_datetime(timestamp) }} (using mireport version {{ software.version | e }}) -->
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{{ reportInfo.entityName | e }}&#8201;&#8212;&#8201;{{ reportInfo.title | e }}&#8201;&#8212;&#8201;{{ macros.render_duration_period_endyear(reportInfo.defaultPeriod) }}</title>
        <style type="text/css">
{% filter cssmin %}
{% include 'style-efrag.css.jinja' %}
{% endfilter %}
        </style>
    </head>
    <body class="theme-{{ theme }}">
        <div style="display:none">
{{ '{{ header }}' }}
        </div>
        <!-- Cover Page -->
        <div class="page portrait-page cover-page">
            <div class="cover-top">
                <div class="cover-headline">
{% if reportInfo.entityName %}
                    <h2 class="entity-name">{{ reportInfo.entityName | e }} </h2>
{% endif %}
{% if reportInfo.title %}
                    <h1 class="report-title">{{ reportInfo.title | e }} </h1>
{% endif %}
{% if reportInfo.subtitle %}
                    <h2 class="report-subtitle">{{ reportInfo.subtitle | e }}</h2>
{% endif %}
{% if reportInfo.defaultPeriod %}
                    <h2 class="report-date">{{ macros.render_duration_period_endyear(reportInfo.defaultPeriod) }}</h2>
{% endif %}
                </div>
            </div>
{% if reportInfo.optionalCoverImage %}
            <div class="cover-image">
                <img src="{{ reportInfo.optionalCoverImage.as_data_url(max_width=500, max_height=500) }}" alt="Cover image" />
            </div>
{% endif %}
{% if reportInfo.optionalLogoImage %}
            <div class="company-logo">
                <img src="{{ reportInfo.optionalLogoImage.as_data_url(max_width=400) }}" alt="{{ reportInfo.entityName | e }} logo" />
            </div>
{% endif %}
        </div>
        <div class="page portrait-page" id="document-information">
            <div class="document-information">
                <h2>Document Information</h2>
                <dl class="document-info-list">
                    {% for item in documentInfo %}
                    <dt>{{ item.key | e }}</dt>
                    <dd>
                        {% if item.format_macro is defined %}
                            {{ macros[item.format_macro](item.value) }}
                        {% else %}
                            {{ item.value | e }}
                        {% endif %}
                    </dd>
                    {% endfor %}
                    <dt>Report generated</dt>
                    <dd>{{ macros.render_datetime(timestamp) }}</dd>
                </dl>
                <div class="document-note">
                    <p>All disclosures are related to the reporting period above unless specified otherwise.</p>
                </div>
            </div>
        </div>
{% if introduction %}
        <div class="page portrait-page" id="introduction">
            <h2>Introduction</h2>
            <div class="introduction-content">
                {{ introduction | e }}
            </div>
        </div>
{% endif %}
        <div class="page portrait-page toc-page" id="table-of-contents">
            <h2>Table of contents</h2>
            <ol class="toc-list">
{% for group in toc %}
    {% if group.heading is not none %}
                <li>
                    <span>{{ group.heading | e }}</span>
                    <ul>
        {% for item in group.items %}
                        <li><a href="#section-class{{ item.idx }}">{{ item.label | e }}</a></li>
        {% endfor %}
                    </ul>
                </li>
    {% else %}
        {% for item in group.items %}
                <li><a href="#section-class{{ item.idx }}">{{ item.label | e }}</a></li>
        {% endfor %}
    {% endif %}
{% endfor %}
            </ol>
        </div>
{% set page = namespace(open=false, prefix='', css_class='') %}
{% for section in sections %}
        {#- Compute this section's page-group key and page class -#}
        {% set current_prefix = page_group_key(section) %}
        {% set current_class = macros.page_class_for_section(section) %}

        {% if section.style is sameas PresentationStyle.List %}
        {#- LIST SECTIONS: merge into same page when prefix and orientation match -#}
            {% if page.open and (current_prefix != page.prefix or current_class != page.css_class) %}
            {{ macros.render_page_footnotes(footnote_manager) }}
        </div>
                {% set page.open = false %}
            {% endif %}
            {% if not page.open %}
        <div class="{{ current_class }}">
                {% set page.open = true %}
                {% set page.prefix = current_prefix %}
                {% set page.css_class = current_class %}
            {% endif %}

            {% set _grp_fn = footnotes_by_group.get(section.presentation.roleUri) %}
            {{ macros.create_h2_title(section, loop, footnote_manager, _grp_fn) }}

            <div class="fact-list">
            {% for rel, factList in section.relationshipToFact.items() %}
                {# Determine alternating shade suffix based on the loop index #}
                {% set shade = 'b' if loop.index0 is even else 'a' %}
                {% for fact in factList %}
                    {% set documentation = rel.concept.getDocumentationLabel() %}
                    <dl class="fact fact-depth-{{ rel.depth if rel.depth <= 4 else 4 }} fact-depth-{{ rel.depth if rel.depth <= 4 else 4 }}-{{ shade }}">
                        <dt class="fact-value {% if fact.concept.isTextblock %}fact-textblock{% endif %}" title="{{ rel.concept.qname }}">{{ macros.render_fact_value(fact) }}{{ macros.footnote_refs(fact.footnotes, footnote_manager) }}{% set ns.fact_count = ns.fact_count + 1 %}</dt>
                        <dd class="fact-label">
                            <span {% if documentation != none %}class="hover-box"{% endif %}>
                                {{ macros.relationship_label(rel) | e }}
                                {% if documentation != none %}
                                <span class="tooltip">
                                    {{ documentation | e }}
                                </span>
                                {% endif %}
                            </span>
                        </dd>
                        {% if fact.hasNonDefaultPeriod %}
                        <dd class="fact-period">Reporting period: {{ macros.render_period(fact) }}</dd>
                        {% endif %}
                        {% set reference = none %}
                        {% if reference != none %}
                        <dd class="fact-ref">{{ documentation | e }}</dd>
                        {% endif %}
                    </dl>
                {% endfor %}
            {% endfor %}
            </div>

        {% elif section.style is sameas PresentationStyle.Table %}
        {#- TABLE SECTIONS: merge into same page when prefix and orientation match -#}
            {% if page.open and (current_prefix != page.prefix or current_class != page.css_class) %}
            {{ macros.render_page_footnotes(footnote_manager) }}
        </div>
                {% set page.open = false %}
            {% endif %}
            {% if not page.open %}
        <div class="{{ current_class }}">
                {% set page.open = true %}
                {% set page.prefix = current_prefix %}
                {% set page.css_class = current_class %}
            {% endif %}

            {% set _grp_fn = footnotes_by_group.get(section.presentation.roleUri) %}
            {{ macros.create_h2_title(section, loop, footnote_manager, _grp_fn) }}

            <table class="thematic-table">
                <thead>
                {% for row in section.table.header_rows %}
                    {% set rowloop = loop %}
                    <tr>
                    {% for column in row %}
                        <th colspan="{{ column.colspan }}" rowspan="{{ column.rowspan }}" class="{% if column.numeric %}numeric{% elif section.table.numeric and not loop.first %}numeric{% elif not loop.first and rowloop.first and (row | count <= 2)  %}center{% else %}noop{% endif %}">
                        {% if column.value is none %}
                            {# nothing to do #}
                        {% elif column.value is string %}
                           {{ column.value | default("") }}
                        {% elif rowloop.first and column.isDuration %}
                            {{ macros.render_duration_period(column.value) }}
                        {% elif column.isDuration %}
                            {{ macros.render_duration_period_endyear(column.value) }}
                        {% elif column.isInstant %}
                            {{ macros.render_instant_period(column.value) }}
                        {% elif column.isConcept %}
                            {{ macros.concept_label(column.value) | e }}
                        {% elif column.isRelationship %}
                            {{ macros.relationship_label(column.value) | e }}
                        {% endif %}
                        </th>
                    {% endfor %}
                    </tr>
                {% endfor %}
                </thead>
                <tbody>
                    {% for row in section.table.rows %}
                    <tr>
                        {% set class = "numeric-row" if section.table.numeric else "row" %}
                        <th class="{{ class }}">
                            {% if row.heading.value is string %}
                                {{ row.heading.value | e }}
                            {% elif row.heading.isConcept %}
                                {{ macros.concept_label(row.heading.value) | e }}
                            {% elif row.heading.isRelationship %}
                                {{ macros.relationship_label(row.heading.value) | e }}
                            {% endif %}
                        </th>
                        {% for cell in row.cells %}
                            {% if cell.fact is none %}
                        <td></td>
                            {% else %}
                        <td {% if cell.fact.concept.isNumeric %}class="numeric"{% endif %}>
                        {{ macros.render_fact_value(cell.fact, cell.suppress_unit) }}{{ macros.footnote_refs(cell.fact.footnotes, footnote_manager) }}{% set ns.fact_count = ns.fact_count + 1 %}
                        </td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
        {#- UNSUPPORTED STYLES: always get their own page -#}
            {% if page.open %}
            {{ macros.render_page_footnotes(footnote_manager) }}
        </div>
                {% set page.open = false %}
            {% endif %}
        <div class="page portrait-page">
            <h2>{{ section_label(section) | e }}</h2>
            <pre>Unsupported presentation style. [{{section.style.name}}{% if section.tabular %}, {{ section.table.style.name }}{% endif %}]</pre>
        </div>
            {% set page.prefix = '' %}
            {% set page.css_class = '' %}
        {% endif %}
{% endfor %}
        {#- Close the last page div if still open -#}
        {% if page.open %}
        {{ macros.render_page_footnotes(footnote_manager) }}
        </div>
        {% endif %}
  <!-- Final Page -->
  <div class="page portrait-page footer-page">
{% if backCoverMatter %}
    <div class="back-cover-matter">
      {{ backCoverMatter | e }}
    </div>
{% endif %}
    <p>This report contains {{ ns.fact_count }} XBRL facts{% if ns.fact_count != uniqueFactCount %} (generated from {{ uniqueFactCount }} unique input facts){% endif %}.</p>
  </div>

</body>
</html>
  
   
   
