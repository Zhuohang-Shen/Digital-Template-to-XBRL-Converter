{% extends "base.html.jinja" %}

{% block title %}Additional Documents Required — VSME XBRL Converter{% endblock %}

{% block content %}

<div class="text-sm text-gray-700 space-y-2">
    <p class="font-medium">Your report contains disclosure fields whose content must be provided as Word documents
        (.docx). Please upload a Word document for each field listed below.</p>
    {% if upload_filename %}
    <p class="text-xs text-gray-500">Continuing conversion for: <strong>{{ upload_filename }}</strong></p>
    {% endif %}
</div>

{% with messages = get_flashed_messages(with_categories=true) %}
{% if messages %}
{% for category, message in messages %}
{% if category == 'error' %}
<div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
    <span class="block sm:inline">{{ message }}</span>
</div>
{% endif %}
{% endfor %}
{% endif %}
{% endwith %}

<form id="partialFactsForm"
    action="{{ url_for('basic.partial_facts_submit', id=conversion_id) }}"
    method="post"
    enctype="multipart/form-data"
    class="space-y-6"
    onsubmit="showSpinner('Converting... Please wait.')">

    {% for concept in concepts %}
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 space-y-3">
        <label class="block text-sm font-semibold text-gray-800"
            for="field_{{ loop.index }}">{{ concept.label }}</label>
        <input
            id="field_{{ loop.index }}"
            type="file"
            name="docx_{{ concept.qname }}"
            accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
            required
            class="block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 p-2"
        >
    </div>
    {% endfor %}

    <div class="flex justify-center">
        <button type="submit"
            class="bg-blue-600 hover:bg-blue-700 focus-visible:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-blue-600 text-white font-medium py-2 px-6 rounded-lg transition"
            style="min-width: 200px;">
            Continue Conversion
        </button>
    </div>
</form>

<div class="flex justify-center">
    <a href="{{ url_for('basic.index') }}"
        class="inline-block px-6 py-2 bg-gray-200 text-gray-700 font-semibold rounded-lg hover:bg-gray-300 transition"
        style="min-width: 200px; text-align: center;">
        Start Over
    </a>
</div>

{% endblock %}
