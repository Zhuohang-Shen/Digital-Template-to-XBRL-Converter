{% extends "base.html.jinja" %}
{% from "_macros.html.jinja" import download_button %}

{% block title %}VSME Digital Template Migration Tool{% endblock %}

{% macro convert_with_old_version() %}
<div class="flex justify-center mt-3">
    <a href="{{ url_for('basic.convert', id=conversion_id, skip_migration=True) }}"
        onclick="showSpinner('Converting... Please wait.')"
        class="inline-block px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-center rounded-lg transition"
        style="min-width: 200px;">
        Convert with old version
    </a>
</div>
{% endmacro %}

{% block content %}

<!-- Back to Home -->
<div class="text-left">
    <a href="{{ url_for('basic.index') }}"
        class="inline-block px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition">
        ← Back to Home
    </a>
</div>

<!-- Intro -->
<p class="text-sm text-gray-700 font-medium">
    Your VSME Template is of an older version. Please use this tool to migrate your data to the newest Template
    version. This step will help the conversion into your digital report.
</p>

<!-- Version Boxes -->
<div class="flex justify-center gap-x-4 my-8">
    <div class="bg-gray-50 rounded-xl p-8 text-center" style="min-width: 300px;">
        <p class="text-3xl font-bold text-gray-800">Your Version: {{ version | default("X.X.X") }}</p>
    </div>
    <div class="bg-blue-50 rounded-xl p-8 text-center" style="min-width: 300px;">
        <p class="text-3xl font-bold text-blue-800">Newest Version: {{ newest_version | default("X.X.X") }}</p>
    </div>
</div>

<!-- New Features -->
<section class="bg-green-50 border-2 border-green-400 rounded-xl p-8 mb-2 text-green-800">
    <h3 class="text-2xl font-bold mb-4">✨ <strong>New Functionalities</strong> of Newest Version</h3>
    <ul class="space-y-3">
        <li class="flex items-start">
            <span class="text-green-600 font-bold mr-3">✓</span>
            <span><strong>Additional languages available</strong></span>
        </li>
        <li class="flex items-start">
            <span class="text-green-600 font-bold mr-3">✓</span>
            <span>Possibility to add <strong>footnotes</strong> to the Template and to have them displayed in the
                digitilised report</span>
        </li>
        <li class="flex items-start">
            <span class="text-green-600 font-bold mr-3">✓</span>
            <span><strong>More flexibility</strong> in personalising the outputs before digital conversion</span>
        </li>
    </ul>
</section>

<!-- File Loaded Info -->
<p class="bg-blue-50 border border-blue-300 rounded-lg p-4 mb-4 text-sm text-blue-800">
    <strong>File loaded:</strong> {{ filename }}
</p>

{% if not has_migration_results %}

<!-- Pre-migration: offer Migrate Template + Convert with old version -->
<form action="{{ url_for('basic.migrationButton', id=conversion_id) }}" method="post"
    onsubmit="showSpinner('Migrating... Please wait.')">
    <div class="flex justify-center">
        <button type="submit"
            class="bg-green-600 hover:bg-green-700 focus-visible:bg-green-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-green-600 text-white font-medium py-2 px-8 rounded-lg transition"
            style="min-width: 200px;">
            Migrate Template
        </button>
    </div>
</form>
{{ convert_with_old_version() }}

{% elif migration_error %}

<!-- Migration failed: show error and allow retry -->
<section id="migrationResults" class="space-y-4 mb-6" tabindex="-1">
    <div class="bg-red-50 border border-red-300 rounded-lg p-4">
        <h3 class="font-semibold text-red-900 mb-2">Migration Failed</h3>
        <p class="text-sm text-red-800">{{ migration_error | e }}</p>
    </div>
</section>
{{ convert_with_old_version() }}

{% else %}

<!-- Post-migration: results + Download Migrated Template -->
<section id="migrationResults" class="space-y-4 mb-6" tabindex="-1">
    <div class="bg-blue-50 border border-blue-300 rounded-lg p-4">
        <h3 class="font-semibold text-blue-900 mb-2">Migration Completed!</h3>
        <p class="text-sm text-blue-800">Time elapsed: <strong>{{ "%.2f"|format(elapsed) }} seconds</strong></p>
    </div>

    {% if migration_issues %}
    <div class="bg-yellow-50 border border-yellow-300 rounded-lg p-4 text-sm text-yellow-800">
        <h3 class="font-semibold text-yellow-900 mb-2">
            Migration Issues (please review the file and correct any issues before proceeding):
        </h3>
        <ul class="list-disc list-outside pl-6 space-y-1">
            {% for issue in migration_issues %}
            <li>{{ issue|e }}</li>
            {% endfor %}
        </ul>
    </div>
    {% else %}
    <div class="bg-green-50 border border-green-300 rounded-lg p-4 space-y-3 text-sm text-green-800">
        <p class="font-semibold">No migration issues detected. ✓</p>
        <div>
            <p class="font-medium mb-2">Next steps:</p>
            <ol class="list-decimal list-outside pl-4 space-y-2">
                <li>
                    <a href="{{ url_for('basic.downloadMigrated', id=conversion_id) }}"
                        class="download-handler text-blue-700 hover:text-blue-900 underline"
                        data-spinner-text="Preparing migrated template">Download the migrated template</a>.
                </li>
                <li>
                    Open it in Excel and save it.
                    <p class="text-xs text-green-700 mt-1">This recalculates formulas and lets you review the migrated
                        values before conversion.</p>
                </li>
                <li>
                    <a href="{{ url_for('basic.index') }}"
                        class="text-blue-700 hover:text-blue-900 underline">Re-upload it on the home page</a>
                    to convert it to XBRL.
                </li>
            </ol>
        </div>
    </div>
    {% endif %}
</section>

<div class="flex flex-wrap justify-center items-center gap-4">
    {{ download_button('migrated', url_for('basic.downloadMigrated', id=conversion_id)) }}
</div>
{{ convert_with_old_version() }}

<script>
    (function () {
        const results = document.getElementById('migrationResults');
        if (results) {
            results.scrollIntoView({ behavior: 'smooth', block: 'start' });
            results.focus({ preventScroll: true });
        }
    })();
</script>

{% endif %}

{% endblock %}