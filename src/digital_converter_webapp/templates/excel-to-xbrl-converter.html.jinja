{% extends "base.html.jinja" %}

{% block title %}VSME Digital Template to XBRL Converter{% endblock %}

{% block content %}


<!-- Info Section -->
<div class="text-sm text-gray-700 space-y-2">
  <p class="font-medium">Follow these steps to convert your VSME Digital Template to the XBRL format:</p>
  <ol class="list-decimal list-inside space-y-1 pl-4">
    <li>Download the <a href="https://xbrl.efrag.org/downloads/vsme/VSME-Digital-Template-latest.xlsx" class="text-blue-600 underline hover:text-blue-800">VSME Digital Template</a> provided by EFRAG (or test the <a href="https://xbrl.efrag.org/downloads/vsme/VSME-Digital-Template-sample-latest.xlsx" class="text-blue-600 underline hover:text-blue-800">sample report</a>).</li>
    <li>Follow the instructions in the Digital Template and fill in the required disclosures in each worksheet. Before starting the conversion, ensure that the Overall Validation Status shows "COMPLETE".</li>
    <li>Select the Digital Template file below and start the conversion. The conversion process may take a few minutes.</li>
    <li>Review the generated XBRL report and the messages to ensure that all disclosures are complete and accurate.</li>
    <li>Download and save your converted XBRL files.</li>
  </ol>
</div>

<!-- Flash Error Messages -->
{% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
    {% for category, message in messages %}
      {% if category == 'error' %}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
          <span class="block sm:inline">{{ message }}</span>
        </div>
      {% endif %}
    {% endfor %}
  {% endif %}
{% endwith %}


<!-- Upload Form -->
<form action="{{ url_for('basic.upload') }}" method="post" enctype="multipart/form-data" class="space-y-4" onsubmit="showSpinner('Converting... Please wait.')">

  <!-- Digital Template File -->
  <div>
    <label for="file" class="block text-sm font-medium text-gray-700 mb-1">Choose the XLSX Digital Template file</label>
    <input type="file" id="file" name="file" accept=".xlsx"
      class="block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
      required />
  </div>


  {% if ENABLE_CAPTCHA %}
  <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}" />
  <input type="hidden" name="captcha_id" value="{{ captcha_id }}" />
  <div>
    <label id="captchaLabel" for="captcha" class="block text-sm font-medium text-gray-700 mb-1">{{ captcha_question }}</label>
    <input type="text" id="captcha" name="captcha"
      title="Please calculate the sum of the two numbers in order to check that you are human."
      class="block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
      required />
  </div>
  {% endif %}

  <!-- Advanced Options -->
  <details class="border border-gray-200 rounded-lg">
    <summary class="cursor-pointer select-none px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg list-none">
      Advanced options
    </summary>
    <div class="px-4 pb-4 pt-4 space-y-4 border-t border-gray-200">

      <!-- Language / Country Formatting -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Report output language and number formatting:
        </label>

        <div class="space-y-2">
          <!-- Option 1: Detect -->
          <label class="flex items-center space-x-2">
            <input type="radio" name="localeOption" value="detect" checked
              class="text-blue-600 focus:ring-blue-500 border-gray-300" />
            <span class="text-sm text-gray-700">Detect from template</span>
          </label>

          <!-- Option 2: Manual -->
          <label class="flex items-center space-x-2">
            <input type="radio" name="localeOption" value="manual"
              class="text-blue-600 focus:ring-blue-500 border-gray-300" />
            <span class="text-sm text-gray-700">Specify manually</span>
          </label>

          <!-- Manual select dropdown -->
          <select id="locale" name="locale" disabled
            class="mt-1 block w-full text-sm font-mono text-gray-800 border border-gray-300 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 hidden">
            <!-- Dynamically populated -->
          </select>
        </div>
      </div>

      <!-- Colour palette -->
      <fieldset>
        <legend class="block text-sm font-medium text-gray-700 mb-2">Report colour</legend>
        <div class="flex flex-wrap gap-3">
          {% for colour in colour_palettes %}
          <label class="cursor-pointer" title="{{ colour.label | capitalize }}">
            <input type="radio" name="style_palette" value="{{ colour.label }}"
                   class="sr-only swatch-radio"
                   {% if colour == default_palette %}checked{% endif %}>
            <span class="block w-7 h-7 rounded-full ring-2 ring-offset-2 transition-all swatch-circle
                         {% if colour == default_palette %}ring-gray-600{% else %}ring-transparent{% endif %}"
                  style="background-color: {{ colour.value }};"></span>
          </label>
          {% endfor %}
          <!-- Custom colour swatch -->
          <label class="cursor-pointer" title="Custom colour" id="custom-colour-label">
            <input type="radio" name="style_palette" value="" id="custom-swatch-radio"
                   class="sr-only swatch-radio">
            <span class="block w-7 h-7 rounded-full ring-2 ring-offset-2 transition-all swatch-circle ring-transparent"
                  id="custom-swatch-circle"
                  style="background: conic-gradient(red,yellow,lime,aqua,blue,magenta,red);"></span>
            <input type="color" id="colour-picker-native" value="#007acc"
                   class="sr-only" tabindex="-1" aria-hidden="true">
          </label>
        </div>
        <!-- Hex text field — shown only when custom swatch is active -->
        <div id="custom-hex-row" class="hidden mt-2 items-center gap-2">
          <input type="text" name="style_colour" id="style-colour-hex"
                 placeholder="#007acc" maxlength="7" pattern="#[0-9A-Fa-f]{6}"
                 class="w-24 text-sm font-mono border border-gray-300 rounded px-2 py-1">
          <span class="w-5 h-5 rounded-full border border-gray-300 shrink-0" id="hex-preview"></span>
        </div>
      </fieldset>

      <!-- Display mode -->
      <fieldset>
        <legend class="block text-sm font-medium text-gray-700 mb-2">Display mode</legend>
        <div class="inline-flex gap-1 text-sm">
          <label id="mode-label-light" class="cursor-pointer px-4 py-1.5 rounded-lg bg-white text-gray-800 font-semibold border-2 border-blue-500 transition-all">
            <input type="radio" name="style_mode" value="light" class="sr-only" checked>
            Light
          </label>
          <label id="mode-label-dark" class="cursor-pointer px-4 py-1.5 rounded-lg bg-gray-800 text-white font-medium border-2 border-gray-600 transition-all">
            <input type="radio" name="style_mode" value="dark" class="sr-only">
            Dark
          </label>
        </div>
      </fieldset>

      <!-- Corporate logo -->
      <div>
        <label for="logo" class="block text-sm font-medium text-gray-700 mb-1">
          Corporate logo
          <span class="text-xs text-gray-500 font-normal">
            — shown on the first page of the report (bottom of the page) as well as in the top right corner for all the other pages of the report. 
            <br />
            (Supported formats: PNG, JPEG, GIF, WEBP. Maximum dimensions: 5000px × 5000px.)
          </span>
        </label>
        <input type="file" id="logo" name="logo"
          accept="image/png,image/jpeg,image/gif,image/webp"
          data-preview="logo-preview"
          class="block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
        <div id="logo-preview" class="mt-2 hidden h-24 w-48 border border-gray-200 rounded bg-gray-50 items-center justify-center overflow-hidden">
          <img src="#" alt="Logo preview" class="max-h-full max-w-full object-contain" />
        </div>
      </div>

      <!-- Cover image -->
      <div>
        <label for="cover" class="block text-sm font-medium text-gray-700 mb-1">
          Cover image
          <span class="text-xs text-gray-500 font-normal">
            — full image displayed in the middle of the cover page. 
            <br />
            (Supported formats: PNG, JPEG, GIF, WEBP. Maximum dimensions: 5000px × 5000px.)
          </span>
        </label>
        <input type="file" id="cover" name="cover"
          accept="image/png,image/jpeg,image/gif,image/webp"
          data-preview="cover-preview"
          class="block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
        <div id="cover-preview" class="mt-2 hidden h-24 w-48 border border-gray-200 rounded bg-gray-50 items-center justify-center overflow-hidden">
          <img src="#" alt="Cover preview" class="max-h-full max-w-full object-contain" />
        </div>
      </div>

      <!-- Background image -->
      <div>
        <label for="background" class="block text-sm font-medium text-gray-700 mb-1">
          Background image
          <span class="text-xs text-gray-500 font-normal">
            — background image displayed in the bottom right corner across all report pages. 
            <br />
            (Supported formats: PNG, JPEG, GIF, WEBP. Maximum dimensions: 5000px × 5000px.)
          </span>
        </label>
        <input type="file" id="background" name="background"
          accept="image/png,image/jpeg,image/gif,image/webp"
          data-preview="background-preview"
          class="block w-full text-sm text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
        <div id="background-preview" class="mt-2 hidden h-24 w-48 border border-gray-200 rounded bg-gray-50 items-center justify-center overflow-hidden">
          <img src="#" alt="Background preview" class="max-h-full max-w-full object-contain" />
        </div>
      </div>

    </div>
  </details>

  <!-- Terms and Conditions -->
  <div class="flex items-center space-x-2">
    <input id="terms" type="checkbox" required
      class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
    <label for="terms" class="text-sm text-gray-600">
      I agree to the
      <button type="button" id="termsButton" onclick="openModal()" class="text-blue-600 underline">terms and conditions</button>.
    </label>
  </div>

  <!-- Submit Button -->
  <button type="submit"
    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition">
    Upload & Convert Digital Template
  </button>

  {% if existing_conversions %}
  <a href="{{ url_for('basic.conversions') }}" class="w-full text-center inline-block px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition">
    Access My Previous Conversions
  </a>
  {% endif %}
</form>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // -----------------------------
  // Locale selection logic
  // -----------------------------
  const select = document.getElementById("locale");
  const radios = document.querySelectorAll('input[name="localeOption"]');
  let normalizedLocales = [];

  async function loadLocaleOptions() {
    const res = await fetch("{{ url_for('basic.available_locales') }}");
    const locales = await res.json();

    normalizedLocales = locales.map(loc => ({
      code: loc.code,
      codeNormalized: loc.code.toLowerCase().replace(/_/g, "-"),
      label: loc.label
    }));

    select.innerHTML = "";

    normalizedLocales.forEach(locale => {
      const option = document.createElement("option");
      option.value = locale.code;
      option.textContent = locale.label;
      select.appendChild(option);
    });
  }

  function detectBestMatch() {
    const browserLocale = (navigator.language || navigator.userLanguage || "")
                          .toLowerCase()
                          .replace(/_/g, "-");

    let match = normalizedLocales.find(loc => loc.codeNormalized === browserLocale);

    if (!match && browserLocale.includes("-")) {
      const baseLang = browserLocale.split("-")[0];
      match = normalizedLocales.find(loc => loc.codeNormalized === baseLang);
      if (!match) {
        match = normalizedLocales.find(loc => loc.codeNormalized.startsWith(baseLang + "-"));
      }
    }

    if (match) {
      select.value = match.code;
    } else {
      select.selectedIndex = -1;
    }
  }

  loadLocaleOptions().then(() => {
    // Enable the select once options are loaded, then pick best match.
    select.disabled = false;
    detectBestMatch();
  });

  radios.forEach(radio => {
    radio.addEventListener("change", () => {
      if (radio.value === "manual" && radio.checked) {
        select.classList.remove("hidden");
        detectBestMatch();
      } else if (radio.value === "detect" && radio.checked) {
        select.classList.add("hidden");
        select.selectedIndex = -1;
      }
    });
  });

  // Image preview — shared across logo, cover, watermark via data-preview attribute
  document.querySelectorAll("input[data-preview]").forEach(input => {
    input.addEventListener("change", () => {
      const preview = document.getElementById(input.dataset.preview);
      const img = preview.querySelector("img");
      const file = input.files[0];
      if (!file) {
        img.src = "#";
        preview.classList.replace("flex", "hidden");
        return;
      }
      const reader = new FileReader();
      reader.onload = e => {
        img.src = e.target.result;
        preview.classList.replace("hidden", "flex");
      };
      reader.readAsDataURL(file);
    });
  });

  // Colour swatch selection — scoped to fieldset so multiple groups could coexist
  document.querySelectorAll(".swatch-radio").forEach(radio => {
    radio.addEventListener("change", () => {
      radio.closest("fieldset").querySelectorAll(".swatch-circle").forEach(circle => {
        circle.classList.remove("ring-gray-600");
        circle.classList.add("ring-transparent");
      });
      radio.parentElement.querySelector(".swatch-circle").classList.replace("ring-transparent", "ring-gray-600");
      if (radio !== customSwatchRadio) {
        hexRow.classList.replace("flex", "hidden");
        hexInput.value = "";
      }
    });
  });

  // Custom colour swatch
  const customSwatchRadio = document.getElementById("custom-swatch-radio");
  const customSwatchCircle = document.getElementById("custom-swatch-circle");
  const nativePicker = document.getElementById("colour-picker-native");
  const hexRow = document.getElementById("custom-hex-row");
  const hexInput = document.getElementById("style-colour-hex");
  const hexPreview = document.getElementById("hex-preview");

  function applyCustomColour(hex) {
    customSwatchCircle.style.background = hex;
    hexPreview.style.background = hex;
    nativePicker.value = hex;
    hexInput.value = hex;
  }

  function showCustomHexRow() {
    hexRow.classList.replace("hidden", "flex");
  }

  customSwatchRadio.addEventListener("change", () => {
    showCustomHexRow();
    nativePicker.click();
  });

  nativePicker.addEventListener("input", () => {
    applyCustomColour(nativePicker.value);
    customSwatchRadio.checked = true;
    customSwatchCircle.classList.replace("ring-transparent", "ring-gray-600");
    showCustomHexRow();
  });

  hexInput.addEventListener("input", () => {
    const val = hexInput.value.trim();
    if (/^#[0-9A-Fa-f]{6}$/.test(val)) {
      nativePicker.value = val;
      customSwatchCircle.style.background = val;
      hexPreview.style.background = val;
    }
  });

  // Display mode — border-2 border-blue-500 shows selection; backgrounds stay fixed
  const modeLabelLight = document.getElementById("mode-label-light");
  const modeLabelDark = document.getElementById("mode-label-dark");
  document.querySelectorAll('input[name="style_mode"]').forEach(radio => {
    radio.addEventListener("change", () => {
      const isLight = radio.value === "light";
      modeLabelLight.classList.toggle("border-blue-500", isLight);
      modeLabelLight.classList.toggle("border-gray-300", !isLight);
      modeLabelLight.classList.toggle("font-semibold", isLight);
      modeLabelLight.classList.toggle("font-medium", !isLight);
      modeLabelDark.classList.toggle("border-blue-500", !isLight);
      modeLabelDark.classList.toggle("border-gray-600", isLight);
      modeLabelDark.classList.toggle("font-semibold", !isLight);
      modeLabelDark.classList.toggle("font-medium", isLight);
    });
  });
});
</script>
{% endblock %}
